{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://database-accelerator.invalid/schemas/benchmark-result-v1.json",
  "title": "Database Accelerator benchmark comparison",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "started_at",
    "completed_at",
    "confidence",
    "environment",
    "workload",
    "direct",
    "accelerator",
    "gains",
    "evidence"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "confidence": { "type": "string", "minLength": 1 },
    "environment": { "$ref": "#/$defs/environment" },
    "workload": { "$ref": "#/$defs/workload" },
    "direct": { "$ref": "#/$defs/pathMetrics" },
    "accelerator": { "$ref": "#/$defs/pathMetrics" },
    "gains": { "$ref": "#/$defs/gains" },
    "evidence": { "$ref": "#/$defs/evidence" }
  },
  "$defs": {
    "environment": {
      "type": "object",
      "required": [
        "server_product",
        "server_version",
        "address",
        "os",
        "arch",
        "logical_cpus",
        "cpu_profile",
        "driver",
        "driver_version",
        "accelerator_version",
        "accelerator_commit",
        "server_settings",
        "server_config_digest"
      ],
      "properties": {
        "server_product": { "enum": ["mysql", "mariadb"] },
        "server_version": { "type": "string", "minLength": 1 },
        "address": { "type": "string", "minLength": 1 },
        "os": { "type": "string", "minLength": 1 },
        "arch": { "type": "string", "minLength": 1 },
        "logical_cpus": { "type": "integer", "minimum": 1 },
        "cpu_profile": { "type": "string", "minLength": 1 },
        "driver": { "type": "string", "minLength": 1 },
        "driver_version": { "type": "string", "minLength": 1 },
        "accelerator_version": { "type": "string" },
        "accelerator_commit": { "type": "string" },
        "server_settings": {
          "type": "object",
          "required": ["max_connections", "innodb_buffer_pool_bytes", "character_set", "collation", "sql_mode", "binlog_format"],
          "properties": {
            "max_connections": { "type": "integer", "minimum": 1 },
            "innodb_buffer_pool_bytes": { "type": "integer", "minimum": 1 },
            "character_set": { "type": "string" },
            "collation": { "type": "string" },
            "sql_mode": { "type": "string" },
            "binlog_format": { "type": "string" }
          },
          "additionalProperties": false
        },
        "server_config_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      },
      "additionalProperties": false
    },
    "workload": {
      "type": "object",
      "required": [
        "name",
        "seed",
        "open_clients",
        "active_concurrency",
        "operations_per_path",
        "dataset_rows",
        "payload_bytes",
        "dataset_estimated_bytes",
        "dataset_digest",
        "storage_engine",
        "network_path",
        "direct_runs",
        "query_shape"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "seed": { "type": "integer" },
        "open_clients": { "type": "integer", "minimum": 2 },
        "active_concurrency": { "type": "integer", "minimum": 1 },
        "operations_per_path": { "type": "integer", "minimum": 1 },
        "dataset_rows": { "type": "integer", "minimum": 1 },
        "payload_bytes": { "type": "integer", "minimum": 1 },
        "dataset_estimated_bytes": { "type": "integer", "minimum": 1 },
        "dataset_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "storage_engine": { "type": "string", "minLength": 1 },
        "network_path": { "type": "string", "minLength": 1 },
        "direct_runs": { "type": "integer", "minimum": 1 },
        "query_shape": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "pathMetrics": {
      "type": "object",
      "required": [
        "client_ready_ms",
        "peak_database_connections",
        "operations",
        "errors",
        "duration_ms",
        "throughput_per_second",
        "p50_ms",
        "p95_ms",
        "p99_ms",
        "max_ms",
        "peak_heap_alloc_bytes",
        "peak_goroutines"
      ],
      "properties": {
        "client_ready_ms": { "type": "number", "minimum": 0 },
        "peak_database_connections": { "type": "integer", "minimum": 0 },
        "operations": { "type": "integer", "minimum": 0 },
        "errors": { "type": "integer", "minimum": 0 },
        "duration_ms": { "type": "number", "minimum": 0 },
        "throughput_per_second": { "type": "number", "minimum": 0 },
        "p50_ms": { "type": "number", "minimum": 0 },
        "p95_ms": { "type": "number", "minimum": 0 },
        "p99_ms": { "type": "number", "minimum": 0 },
        "max_ms": { "type": "number", "minimum": 0 },
        "peak_heap_alloc_bytes": { "type": "integer", "minimum": 0 },
        "peak_goroutines": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "gains": {
      "type": "object",
      "required": ["connections_saved", "connection_reduction_percent", "fan_in_ratio", "client_ready_speedup", "throughput_change_percent", "p95_latency_change_percent"],
      "properties": {
        "connections_saved": { "type": "integer" },
        "connection_reduction_percent": { "type": "number" },
        "fan_in_ratio": { "type": "number" },
        "client_ready_speedup": { "type": "number" },
        "throughput_change_percent": { "type": "number" },
        "p95_latency_change_percent": { "type": "number" }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": ["measured", "experimental", "scope", "caveat"],
      "properties": {
        "measured": { "type": "boolean" },
        "experimental": { "type": "boolean" },
        "scope": { "type": "string", "minLength": 1 },
        "caveat": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
